{
  "name": "MatchmakerLike",
  "type": "object",
  "properties": {
    "liker_email": {
      "type": "string"
    },
    "liker_name": {
      "type": "string"
    },
    "liked_email": {
      "type": "string"
    },
    "is_super_like": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "liker_email",
    "liker_name",
    "liked_email"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.liker_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.liker_email": "{{user.email}}"
        },
        {
          "data.liked_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.liker_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.liker_email": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}