{
  "name": "Like",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string",
      "description": "ID of the liked post"
    },
    "user_email": {
      "type": "string",
      "description": "Email of the user who liked the post"
    }
  },
  "required": [
    "post_id",
    "user_email"
  ],
  "rls": {
    "read": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "write": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}